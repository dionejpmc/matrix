CALL db.schema.visualization();
CALL db.labels();
CALL db.relationshipTypes();
CALL db.propertyKeys();

Conceito SQL (Relacional),         Conceito Neo4j (Grafos),         Comando de Inspeção
Tabela,                            Label (Rótulo de Nó),            CALL db.labels();
Linha/Registro,                    Node (Nó),                       MATCH (n:Label) RETURN n;
Coluna,                            Property (Propriedade),          CALL db.propertyKeys();
Foreign Key / Join,                Relationship (Relacionamento),   CALL db.relationshipTypes();


